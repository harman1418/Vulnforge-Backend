# MongoDB Connection
MONGODB_URL=mongodb://localhost:27017/vulnforge

# JWT & Security (⚠️ CHANGE THESE IN PRODUCTION)
SECRET_KEY=your-super-secret-key-change-this-in-production-use-256-bits-minimum
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Email Configuration
EMAIL=noreply@vulnforge.app
EMAIL_PASSWORD=your-email-api-key-or-password

# Cloudflare AI (For vulnerability analysis)
CF_ACCOUNT_ID=your-cloudflare-account-id
CF_API_TOKEN=your-cloudflare-api-token

# CORS & Hosts (Whitelist your frontend domain)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://yourdomain.com
TRUSTED_HOSTS=localhost,127.0.0.1,*.azurewebsites.net,yourdomain.com

# API Configuration
PORT=8000
ENVIRONMENT=development

# Logging
LOG_LEVEL=INFO
