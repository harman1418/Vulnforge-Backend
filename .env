# MongoDB Connection
MONGODB_URL=mongodb://localhost:27017/vulnforge

# JWT & Security
SECRET_KEY=your-super-secret-key-change-this-in-production-use-256-bits-minimum
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Email Configuration
EMAIL=noreply@vulnforge.app
EMAIL_PASSWORD=

# Cloudflare AI
CF_ACCOUNT_ID=
CF_API_TOKEN=

# CORS & Hosts
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
TRUSTED_HOSTS=localhost,127.0.0.1,*.azurewebsites.net

# API Configuration
PORT=8000
ENVIRONMENT=development

# Logging
LOG_LEVEL=INFO
